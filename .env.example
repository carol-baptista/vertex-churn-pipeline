# Copy to .env and fill in your values (never commit .env)
GCP_PROJECT_ID=churn-predictor-ml-2026
GCP_REGION=us-west1
GCS_BUCKET=churn-predictor-ml-artifacts

# BigQuery
BQ_DATASET=churn_ml
BQ_TABLE=customers

# Source CSV object in the bucket (Phase 1)
GCS_CSV_OBJECT=telco-customer-churn.csv

# Vertex AI
VERTEX_MODEL_DISPLAY_NAME=churn-predictor
VERTEX_ENDPOINT_DISPLAY_NAME=churn-endpoint
VERTEX_ARTIFACT_REPO=vertex-churn
VERTEX_SERVING_IMAGE=churn-rf-serving
VERTEX_MACHINE_TYPE=n1-standard-2
